# ═══════════════════════════════════════════════════════════════════════
# SREMS Frontend - Environment Configuration Template
# Copy this file to .env and update with your values
# ═══════════════════════════════════════════════════════════════════════

# API Configuration
# Backend server URL (without trailing slash)
VITE_API_BASE_URL=http://localhost:8082

# Backend service path
VITE_API_SERVICE_PATH=/software-management-service

# API version
VITE_API_VERSION=/api/v1

# Application Configuration
# Application name (shown in titles, etc)
VITE_APP_NAME=SREMS Frontend

# Environment: development, staging, production
VITE_ENVIRONMENT=development

# Features
# Enable console logging
VITE_ENABLE_LOGGING=true

# Logging level: debug, info, warn, error
VITE_LOG_LEVEL=info

# Session Configuration
# Session timeout in minutes (after which user is logged out)
VITE_SESSION_TIMEOUT_MINUTES=30

# Token refresh interval in minutes (how often to refresh JWT)
VITE_TOKEN_REFRESH_INTERVAL_MINUTES=5

# ═══════════════════════════════════════════════════════════════════════
# PRODUCTION VALUES (reference)
# ═══════════════════════════════════════════════════════════════════════
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_ENVIRONMENT=production
# VITE_ENABLE_LOGGING=false
# VITE_SESSION_TIMEOUT_MINUTES=60
